{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VerificationReport",
  "type": "object",
  "required": ["status", "checks"],
  "properties": {
    "status": { "type": "string", "enum": ["pass", "fail"] },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "result"],
        "properties": {
          "name": { "type": "string" },
          "result": { "type": "string", "enum": ["pass", "fail"] },
          "evidence": { "type": "string" }
        }
      }
    }
  }
}
