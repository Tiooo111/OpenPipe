{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PackManifest",
  "type": "object",
  "required": ["packId", "version", "artifacts"],
  "properties": {
    "packId": { "type": "string" },
    "version": { "type": "string" },
    "artifacts": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
